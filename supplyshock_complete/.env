# SupplyShock Predictor — Environment Variables

PORT=3000
NODE_ENV=development
DATA_MODE=mock

# ── Country-specific MarineTraffic API Keys ─────────────────────────────────
# Get keys at: https://www.marinetraffic.com/en/online-services/plans
MARINETRAFFIC_API_KEY_IN=your_india_marinetraffic_key_here
MARINETRAFFIC_API_KEY_IR=your_iran_marinetraffic_key_here
MARINETRAFFIC_API_KEY_US=your_usa_marinetraffic_key_here
MARINETRAFFIC_API_KEY_RU=your_russia_marinetraffic_key_here

# ── OpenWeatherMap API Key (shared) ──────────────────────────────────────────
# Get key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ── PortWatch API Keys (per country) ─────────────────────────────────────────
# Get keys at: https://portwatch.imf.org
PORTWATCH_API_KEY_IN=your_india_portwatch_key_here
PORTWATCH_API_KEY_IR=your_iran_portwatch_key_here
PORTWATCH_API_KEY_US=your_usa_portwatch_key_here
PORTWATCH_API_KEY_RU=your_russia_portwatch_key_here

# ── Map Tiles (no key needed — uses ESRI satellite tiles) ─────────────────────
# Optional Mapbox token for custom styling: https://account.mapbox.com
# MAPBOX_TOKEN=your_mapbox_token_here

# ── Risk Thresholds ────────────────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=70
MEDIUM_RISK_THRESHOLD=40
